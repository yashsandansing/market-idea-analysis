{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "devCommand": "cd frontend && npm run dev -- --port $PORT",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.py": {
      "runtime": "python3.12",
      "maxDuration": 60
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "^/@(.*)", "dest": "/@$1" },
    { "src": "^/__(.*)$", "dest": "/__$1" },
    { "handle": "filesystem" },
    { "src": "^(?!.*\\.[^/]+$).*", "dest": "/index.html" }
  ]
}
